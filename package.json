{
  "name": "sigilbound",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A top-down pixel adventure with player-crafted spells and instanced turn-based combat.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "genmaps": "node --experimental-strip-types --no-warnings scripts/genmaps.ts",
    "genicons": "node --experimental-strip-types --no-warnings scripts/genicons.ts",
    "zip": "npm run build && cd dist && zip -rq ../sigilbound-itch.zip ."
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
